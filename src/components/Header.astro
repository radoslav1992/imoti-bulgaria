---
interface Props {
  date: string;
}

const { date } = Astro.props;

const formatted = new Date(date).toLocaleDateString("bg-BG", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<header class="hero">
  <div class="wrap">
    <h1 class="hero__title">Средни цени на имоти</h1>
    <p class="hero__date">Обновено на {formatted}</p>
  </div>
</header>

<style>
  .hero {
    padding: 1.25rem 0 0.5rem;
  }

  .hero__title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .hero__date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 1.75rem 0 0.75rem;
    }

    .hero__title {
      font-size: 1.5rem;
    }
  }
</style>
